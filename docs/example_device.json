{
  "device_id": "example_hybrid_v1",
  "name": "Example Hybrid Inverter",
  "description": "Template combining flat single-register reads, block (group) reads, bitfield decoding, and NaN sentinels. Adjust register addresses, types, and scaling based on your device's Modbus documentation.",
  "schema_version": 2,
  "registers": [
    {
      "addr": "0x0050",
      "name": "device_state",
      "fc": 4,
      "type": "uint16",
      "scale": 1.0,
      "unit": "",
      "comment": "Standalone status register, polled with its own Modbus transaction"
    }
  ],
  "groups": [
    {
      "name": "ac_block",
      "fc": 4,
      "start": "0x0000",
      "count": 18,
      "storage": false,
      "fields": [
        { "offset": 0,  "name": "voltage_l1",   "type": "uint16", "scale": 0.1,  "unit": "V" },
        { "offset": 1,  "name": "voltage_l2",   "type": "uint16", "scale": 0.1,  "unit": "V" },
        { "offset": 2,  "name": "voltage_l3",   "type": "uint16", "scale": 0.1,  "unit": "V" },
        { "offset": 3,  "name": "current_l1",   "type": "uint16", "scale": 0.01, "unit": "A" },
        { "offset": 6,  "name": "frequency",    "type": "uint16", "scale": 0.01, "unit": "Hz" },
        { "offset": 10, "name": "active_power", "type": "int32",  "scale": 1.0,  "unit": "W",  "comment": "spans offsets 10 and 11" },
        { "offset": 14, "name": "energy_today", "type": "uint32", "scale": 0.1,  "unit": "kWh" }
      ]
    },
    {
      "name": "battery_block",
      "fc": 4,
      "start": "0x0100",
      "count": 6,
      "storage": true,
      "fields": [
        { "offset": 0, "name": "battery_voltage", "type": "uint16", "scale": 0.01, "unit": "V" },
        { "offset": 1, "name": "battery_current", "type": "int16",  "scale": 0.1,  "unit": "A",  "comment": "positive=charging, negative=discharging" },
        { "offset": 2, "name": "battery_power",   "type": "int32",  "scale": 1.0,  "unit": "W" },
        { "offset": 4, "name": "battery_soc",     "type": "uint16", "scale": 1.0,  "unit": "%",  "nan_value": "0xFFFF", "comment": "0xFFFF means not reported by BMS, suppressed from publish" },
        { "offset": 5, "name": "battery_soh",     "type": "uint16", "scale": 1.0,  "unit": "%",  "nan_value": "0xFFFF" }
      ]
    },
    {
      "name": "alarms",
      "fc": 4,
      "start": "0x0200",
      "count": 1,
      "storage": false,
      "fields": [
        {
          "offset": 0,
          "name": "alarm_word",
          "type": "uint16",
          "scale": 1.0,
          "unit": "",
          "comment": "Raw value is suppressed when bits[] is present; only named bits are published.",
          "bits": [
            { "mask": "0x0001", "name": "fault_grid" },
            { "mask": "0x0002", "name": "fault_pv" },
            { "mask": "0x0004", "name": "fault_battery" },
            { "mask": "0x00F0", "name": "operating_state", "comment": "multi-bit field, mask 0x00F0 yields 0..15" }
          ]
        }
      ]
    }
  ]
}
