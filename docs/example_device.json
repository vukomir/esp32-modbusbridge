{
  "device_id": "example_inverter_v1",
  "name": "Example Solar Inverter",
  "description": "Template for creating custom device configurations. Modify register addresses, types, and scaling based on your device's Modbus documentation.",
  "registers": [
    {
      "addr": "0x0000",
      "name": "voltage",
      "fc": 4,
      "type": "uint16",
      "scale": 0.1,
      "unit": "V",
      "storage": false,
      "comment": "AC voltage - example: raw 2300 * 0.1 = 230.0V"
    },
    {
      "addr": "0x0001",
      "name": "current",
      "fc": 4,
      "type": "uint16",
      "scale": 0.01,
      "unit": "A",
      "storage": false,
      "comment": "AC current - example: raw 523 * 0.01 = 5.23A"
    },
    {
      "addr": "0x0002",
      "name": "frequency",
      "fc": 4,
      "type": "uint16",
      "scale": 0.01,
      "unit": "Hz",
      "storage": false,
      "comment": "Grid frequency - example: raw 5000 * 0.01 = 50.00 Hz"
    },
    {
      "addr": "0x0010",
      "name": "active_power",
      "fc": 4,
      "type": "uint32",
      "scale": 1.0,
      "unit": "W",
      "storage": false,
      "comment": "32-bit power - reads 2 registers (0x0010 and 0x0011)"
    },
    {
      "addr": "0x0020",
      "name": "energy_today",
      "fc": 4,
      "type": "uint32",
      "scale": 0.1,
      "unit": "kWh",
      "storage": false,
      "comment": "Daily energy - example: raw 125 * 0.1 = 12.5 kWh"
    },
    {
      "addr": "0x0022",
      "name": "energy_total",
      "fc": 4,
      "type": "uint32",
      "scale": 0.1,
      "unit": "kWh",
      "storage": false,
      "comment": "Total lifetime energy production"
    },
    {
      "addr": "0x0030",
      "name": "pv1_voltage",
      "fc": 4,
      "type": "uint16",
      "scale": 0.1,
      "unit": "V",
      "storage": false,
      "comment": "PV string 1 voltage"
    },
    {
      "addr": "0x0031",
      "name": "pv1_current",
      "fc": 4,
      "type": "uint16",
      "scale": 0.01,
      "unit": "A",
      "storage": false,
      "comment": "PV string 1 current"
    },
    {
      "addr": "0x0040",
      "name": "temperature",
      "fc": 4,
      "type": "int16",
      "scale": 0.1,
      "unit": "C",
      "storage": false,
      "comment": "Signed temperature - can be negative in winter"
    },
    {
      "addr": "0x0050",
      "name": "device_state",
      "fc": 4,
      "type": "uint16",
      "scale": 1.0,
      "unit": "",
      "storage": false,
      "comment": "Status code: 0=Wait, 1=Normal, 2=Fault, etc."
    },
    {
      "addr": "0x0100",
      "name": "battery_voltage",
      "fc": 4,
      "type": "uint16",
      "scale": 0.01,
      "unit": "V",
      "storage": true,
      "comment": "Battery registers marked as storage=true are read separately"
    },
    {
      "addr": "0x0101",
      "name": "battery_current",
      "fc": 4,
      "type": "int16",
      "scale": 0.1,
      "unit": "A",
      "storage": true,
      "comment": "Signed: positive=charging, negative=discharging"
    },
    {
      "addr": "0x0102",
      "name": "battery_power",
      "fc": 4,
      "type": "int32",
      "scale": 1.0,
      "unit": "W",
      "storage": true,
      "comment": "32-bit signed battery power"
    },
    {
      "addr": "0x0104",
      "name": "battery_soc",
      "fc": 4,
      "type": "uint16",
      "scale": 1.0,
      "unit": "%",
      "storage": true,
      "comment": "State of Charge - NOTE: Usually returns 0-100 directly, not scaled!"
    },
    {
      "addr": "0x0105",
      "name": "battery_soh",
      "fc": 4,
      "type": "uint16",
      "scale": 1.0,
      "unit": "%",
      "storage": true,
      "comment": "State of Health - NOTE: Usually returns 0-100 directly, not scaled!"
    }
  ]
}
